---
import { url } from '../lib/utils';
---

<section class="section-sand section-padding">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-center max-w-wide mx-auto">
      <!-- Photo -->
      <div class="lg:col-span-2">
        <div class="rounded-lg overflow-hidden aspect-[3/4] bg-charcoal">
          <img src={url('/images/rider-1.jpg')} alt="Zach Janik, Founder of American Moto Co." class="img-cover img-documentary" loading="lazy" />
        </div>
      </div>
      <!-- Bio -->
      <div class="lg:col-span-3">
        <span class="text-sage font-heading font-semibold text-xs uppercase tracking-widest">Founder</span>
        <h2 class="text-h2 text-ink mt-1 mb-4">Zach Janik</h2>
        <div class="space-y-4 text-ink-light text-base leading-relaxed">
          <p>
            I founded American Moto Co. to bridge the gap between every niche in the riding world. Watching new riders struggle with intimidation, conflicting online advice, and the "pay-to-play" feel of big-media reviews reminded me why I started: the motorcycle community should be accessible to everyone.
          </p>
          <p>
            Whether I'm interviewing land-speed record holders or helping a beginner pick their first set of gear, my mission is to share the stories of the ride.
          </p>
          <p>
            American Moto Co. is more than a website; it's a community-driven legacy built to welcome the next generation of riders while honoring the miles of the tenured.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
