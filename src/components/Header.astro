---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Stories', href: '/stories' },
  { label: 'About', href: '/about' },
  { label: 'Submit', href: '/submit' },
];
---

<header class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" id="site-header">
  <div class="container-site">
    <nav class="flex items-center justify-between h-[72px]" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="American Moto Co. — Home">
        <img
          src="/images/logo.png"
          alt="American Moto Co."
          class="h-8 sm:h-10 w-auto invert mix-blend-screen transition-opacity group-hover:opacity-80"
          id="header-logo"
        />
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'nav-link font-heading font-medium text-sm uppercase tracking-wider transition-colors duration-200 hover:text-gold',
                currentPath === link.href ? 'text-gold' : 'text-white/80',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="#subscribe"
            class="font-heading font-semibold text-sm uppercase tracking-wider bg-gold text-dark px-5 py-2 rounded hover:bg-gold/90 transition-colors duration-200 cursor-pointer"
          >
            Subscribe
          </a>
        </li>
      </ul>

      <!-- Mobile Menu Button -->
      <button
        class="md:hidden text-white hover:text-gold transition-colors cursor-pointer p-2"
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-dark/98 backdrop-blur-sm border-t border-white/10" role="navigation" aria-label="Mobile navigation">
    <div class="container-site py-6">
      <ul class="flex flex-col gap-4">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'block font-heading font-medium text-lg uppercase tracking-wider transition-colors duration-200 hover:text-gold py-2',
                currentPath === link.href ? 'text-gold' : 'text-white/80',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="#subscribe"
            class="inline-block font-heading font-semibold text-sm uppercase tracking-wider bg-gold text-dark px-6 py-3 rounded hover:bg-gold/90 transition-colors duration-200 cursor-pointer"
          >
            Subscribe
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const logo = document.getElementById('header-logo');

  window.addEventListener('scroll', () => {
    if (header && logo) {
      if (window.scrollY > 80) {
        header.classList.add('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
      } else {
        header.classList.remove('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
      }
    }
  });

  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuBtn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
