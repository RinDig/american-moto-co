---
import { url } from '../lib/utils';
---

<section class="relative h-[90vh] min-h-[600px] max-h-[900px] flex items-center justify-center overflow-hidden">
  <img
    src={url('/images/hero-forest-pov.jpg')}
    alt="Point of view riding a motorcycle through a forest road"
    class="absolute inset-0 img-cover img-documentary"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-dark/70 via-dark/40 to-dark/80"></div>

  <div class="relative z-10 container-site text-center px-4">
    <!-- Logo -->
    <div class="mb-4">
      <img src={url('/images/logo.png')} alt="American Moto Co." class="h-14 sm:h-18 mx-auto invert mix-blend-screen" />
    </div>

    <!-- Tagline -->
    <p class="text-xl sm:text-2xl text-white/90 max-w-xl mx-auto mb-8 font-heading font-medium italic">
      Sharing the stories from the road
    </p>

    <!-- Subscribe Form -->
    <form class="flex flex-col sm:flex-row gap-3 justify-center items-center max-w-lg mx-auto mb-6" onsubmit="event.preventDefault()">
      <input
        type="email"
        placeholder="Email"
        class="w-full sm:w-auto flex-1 bg-white border border-white/80 rounded-lg px-5 py-3.5 text-dark placeholder:text-dark/40 focus:outline-none focus:ring-2 focus:ring-gold/40 transition-all text-center sm:text-left text-base"
        aria-label="Email address for newsletter"
      />
      <button
        type="submit"
        class="w-full sm:w-auto bg-dark text-white font-heading font-bold uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-dark/80 transition-all cursor-pointer text-sm border border-white/20"
      >
        Subscribe
      </button>
    </form>

    <!-- Bottom tagline -->
    <p class="text-white font-heading font-bold text-lg sm:text-xl tracking-wide">
      Built for riders, who just want to ride.
    </p>

    <!-- Quick links -->
    <div class="flex flex-wrap justify-center gap-4 mt-6">
      <a href={url('/stories/')} class="text-white/60 hover:text-gold text-xs font-heading uppercase tracking-wider transition-colors cursor-pointer">Previous Issues</a>
      <span class="text-white/20">|</span>
      <a href={url('/contact/')} class="text-white/60 hover:text-gold text-xs font-heading uppercase tracking-wider transition-colors cursor-pointer">Get in Touch</a>
      <span class="text-white/20">|</span>
      <a href={url('/contact/')} class="text-white/60 hover:text-gold text-xs font-heading uppercase tracking-wider transition-colors cursor-pointer">Suggest an Interview</a>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/40 animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7" /></svg>
  </div>
</section>
